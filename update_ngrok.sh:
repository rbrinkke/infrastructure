#!/bin/bash

# Variabelen
DOWNLOAD_URL="https://bin.equinox.io/c/4VmDzA7iaHb/ngrok-v3-stable-linux-amd64.tgz"
NGROK_BIN="/usr/local/bin/ngrok"
AUTH_TOKEN="<YOUR_NEW_AUTHTOKEN>"  # Vervang dit met je echte authtoken
LOGFILE="$HOME/ngrok_update.log"

echo "===== Ngrok Update Script =====" | tee "$LOGFILE"

# Stap 1: Download de nieuwste versie
echo "1. Downloading the latest version of Ngrok..." | tee -a "$LOGFILE"
wget -O /tmp/ngrok.tgz "$DOWNLOAD_URL" >> "$LOGFILE" 2>&1

if [ $? -ne 0 ]; then
    echo "ERROR: Failed to download Ngrok. Check your internet connection." | tee -a "$LOGFILE"
    exit 1
fi

# Stap 2: Extract the downloaded file
echo "2. Extracting Ngrok..." | tee -a "$LOGFILE"
tar -xvzf /tmp/ngrok.tgz -C /tmp >> "$LOGFILE" 2>&1

if [ $? -ne 0 ]; then
    echo "ERROR: Failed to extract Ngrok." | tee -a "$LOGFILE"
    exit 1
fi

# Stap 3: Replace the old version
echo "3. Replacing the old Ngrok binary..." | tee -a "$LOGFILE"
sudo mv /tmp/ngrok "$NGROK_BIN" >> "$LOGFILE" 2>&1
if [ $? -ne 0 ]; then
    echo "ERROR: Failed to move Ngrok binary to $NGROK_BIN." | tee -a "$LOGFILE"
    exit 1
fi

sudo chmod +x "$NGROK_BIN" >> "$LOGFILE" 2>&1

# Stap 4: Check the installed version
echo "4. Verifying the installed version..." | tee -a "$LOGFILE"
NGROK_VERSION=$($NGROK_BIN version | grep -oP "(?<=ngrok version )\S+")
if [[ $NGROK_VERSION < "3.2.0" ]]; then
    echo "ERROR: Installed Ngrok version ($NGROK_VERSION) is still outdated." | tee -a "$LOGFILE"
    exit 1
fi
echo "   - Installed Ngrok version: $NGROK_VERSION" | tee -a "$LOGFILE"

# Stap 5: Set the authtoken
echo "5. Setting authtoken..." | tee -a "$LOGFILE"
$NGROK_BIN authtoken "$AUTH_TOKEN" >> "$LOGFILE" 2>&1

if [ $? -ne 0 ]; then
    echo "ERROR: Failed to set authtoken." | tee -a "$LOGFILE"
    exit 1
fi
echo "   - Authtoken successfully set." | tee -a "$LOGFILE"

# Stap 6: Clean up
echo "6. Cleaning up temporary files..." | tee -a "$LOGFILE"
rm -rf /tmp/ngrok.tgz /tmp/ngrok >> "$LOGFILE" 2>&1

echo "===== Ngrok Update Completed =====" | tee -a "$LOGFILE"

